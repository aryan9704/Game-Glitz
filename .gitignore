# Environment — never commit real credentials
server/.env
.env
*.env

# SQLite database files — regenerated from seed data on first boot
server/*.db
server/*.db-shm
server/*.db-wal

# JWT secret file (auto-generated, machine-specific)
server/.jwt-secret
server/.jwt-secret-auto
server/.mail-previews/
server/.tmp_*
server/*.log

# Node dependencies
server/node_modules/
node_modules/

# Release artifacts
dist-release/
*.zip

# Backup/scratch files
*.bak
*.orig

# OS junk
.DS_Store
Thumbs.db

# Editor files
.vscode/
*.swp
