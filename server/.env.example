# ─────────────────────────────────────────────────────────────────
# GameGlitz Server — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────
PORT=3000

# Comma-separated list of allowed CORS origins.
# For local dev: http://localhost:3000
# For production: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# JWT signing secret — generate with: node -e "process.stdout.write(require('crypto').randomBytes(64).toString('hex'))"
# Leave blank only for local development — the server will use an in-memory
# secret and all tokens will become invalid when the process restarts.
JWT_SECRET=

# ── OAuth (optional — leave blank to disable each provider) ──────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
STEAM_API_KEY=
OAUTH_CALLBACK_BASE=http://localhost:3000

# ── Database ─────────────────────────────────────────────────────
# Default: SQLite — no setup required, database is created automatically.
# DB_MODE can be: sqlite, sqlserver, or hybrid.
# Hybrid mode uses DB_PRIMARY for reads and mirrors writes to both databases.
DB_MODE=sqlite
DB_PRIMARY=sqlite
DB_SYNC_ON_STARTUP=true

# Legacy fallback if DB_MODE is not set.
USE_SQL_SERVER=false

# SQL Server settings (used when DB_MODE=sqlserver or DB_MODE=hybrid)
SQLSERVER_HOST=localhost
SQLSERVER_INSTANCE=SQLEXPRESS
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=GameGlitz
SQLSERVER_AUTH=sql
SQLSERVER_USER=sa
SQLSERVER_PASSWORD=YourStrongPasswordHere
SQLSERVER_DOMAIN=
SQLSERVER_ENCRYPT=false
SQLSERVER_TRUST_CERT=true

# ── Stripe (test mode) ──────────────────────────────────────────
# Get your test keys from https://dashboard.stripe.com/test/apikeys
# Leave blank to disable Stripe — the /api/checkout/stripe route will return 503.
STRIPE_SECRET_KEY=
# Generate a webhook signing secret in the Stripe dashboard after creating a webhook
# endpoint pointed at: <your-domain>/api/checkout/stripe/webhook
STRIPE_WEBHOOK_SECRET=

# Email delivery (Resend)
# Create an API key at https://resend.com and verify your sending domain.
# In production, verification/reset emails require both values below.
RESEND_API_KEY=
EMAIL_FROM=
# Optional local-only fallback. When true, email previews are written to
# server/.mail-previews/ instead of being printed to stdout.
EMAIL_PREVIEW=false

# ── ZeroBounce (email deliverability check at signup) ───────────
# Sign up at https://www.zerobounce.net/ and copy your API key here.
# Leave blank to skip the check — registration will still work.
ZEROBOUNCE_API_KEY=

# ── Public URL (used in email links) ────────────────────────────
# e.g. https://gameglitz.example.com — leave blank to use request host
PUBLIC_URL=
